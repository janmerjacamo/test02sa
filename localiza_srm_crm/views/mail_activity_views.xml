<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mail_activity_form_localiza_srm" model="ir.ui.view">
        <field name="name">mail.activity.form.localiza.srm</field>
        <field name="model">mail.activity</field>
        <field name="inherit_id" ref="mail.mail_activity_view_form_popup"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="localiza_priority"/>
                <field name="localiza_state"/>
            </xpath>
        </field>
    </record>

    <record id="view_mail_activity_list_localiza_srm" model="ir.ui.view">
        <field name="name">mail.activity.list.localiza.srm</field>
        <field name="model">mail.activity</field>
        <field name="arch" type="xml">
            <list string="Actividades Localiza">
                <field name="date_deadline"/>
                <field name="summary"/>
                <field name="activity_type_id"/>
                <field name="user_id"/>
                <field name="localiza_priority"/>
                <field name="localiza_state"/>
                <field name="res_model"/>
                <field name="res_id"/>
            </list>
        </field>
    </record>

    <record id="action_localiza_activities_today" model="ir.actions.act_window">
        <field name="name">Actividades de hoy</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('date_deadline','=', context_today())]</field>
    </record>

    <record id="action_localiza_activities_overdue" model="ir.actions.act_window">
        <field name="name">Actividades vencidas</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('date_deadline','&lt;', context_today())]</field>
    </record>

    <record id="action_localiza_activities_pending" model="ir.actions.act_window">
        <field name="name">Actividades pendientes</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
    </record>
</odoo>
