<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_localiza_bodega" model="res.groups.privilege">
        <field name="name">Bodega Operativa</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_localiza_bodega_user" model="res.groups">
        <field name="name">Usuario</field>
        <field name="privilege_id" ref="localiza_bodega_operativa.privilege_localiza_bodega"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <record id="group_localiza_bodega_manager" model="res.groups">
        <field name="name">Responsable</field>
        <field name="privilege_id" ref="localiza_bodega_operativa.privilege_localiza_bodega"/>
        <field name="implied_ids" eval="[(4, ref('localiza_bodega_operativa.group_localiza_bodega_user')), (4, ref('stock.group_stock_manager'))]"/>
    </record>
</odoo>
