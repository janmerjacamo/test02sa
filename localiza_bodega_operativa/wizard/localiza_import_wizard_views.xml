<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_localiza_import_wizard_form" model="ir.ui.view">
        <field name="name">localiza.import.wizard.form</field>
        <field name="model">localiza.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Excel Localiza">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="import_type"/>
                            <field name="location_id"/>
                            <field name="create_stock"/>
                        </group>
                        <group>
                            <field name="filename" invisible="1"/>
                            <field name="file" filename="filename"/>
                        </group>
                    </group>
                    <group string="Vista previa / resultado">
                        <field name="preview" nolabel="1" readonly="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_preview" type="object" string="Vista previa" class="btn-secondary"/>
                    <button name="action_import" type="object" string="Importar" class="btn-primary"/>
                    <button string="Cerrar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_localiza_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar Excel</field>
        <field name="res_model">localiza.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
