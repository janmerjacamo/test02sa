<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_localiza_dashboard" model="ir.actions.act_window">
        <field name="name">Tablero Bodega</field>
        <field name="res_model">localiza.entrega</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Bienvenido a Localiza Bodega Operativa</p>
            <p>Registra puestos, carga inventario desde Excel y controla entregas con movimientos reales de Inventario.</p>
        </field>
    </record>

    <record id="view_localiza_entrega_kanban" model="ir.ui.view">
        <field name="name">localiza.entrega.kanban</field>
        <field name="model">localiza.entrega</field>
        <field name="arch" type="xml">
            <kanban class="o_localiza_kanban" default_group_by="state">
                <field name="name"/>
                <field name="date"/>
                <field name="tipo"/>
                <field name="receptor"/>
                <field name="puesto_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click localiza-card">
                            <div class="localiza-card-title">
                                <field name="name"/>
                            </div>
                            <div class="localiza-card-meta">
                                <span><field name="date"/></span>
                                <span> · </span>
                                <span><field name="tipo"/></span>
                            </div>
                            <div class="localiza-card-body">
                                <strong><field name="receptor"/></strong><br/>
                                <span><field name="puesto_id"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
