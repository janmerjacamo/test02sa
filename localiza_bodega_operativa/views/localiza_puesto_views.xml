<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_localiza_puesto_list" model="ir.ui.view">
        <field name="name">localiza.puesto.list</field>
        <field name="model">localiza.puesto</field>
        <field name="arch" type="xml">
            <list string="Puestos" decoration-muted="state == 'baja'">
                <field name="code"/>
                <field name="name"/>
                <field name="tipo"/>
                <field name="partner_id"/>
                <field name="supervisor_id"/>
                <field name="agentes"/>
                <field name="state" widget="badge" decoration-success="state == 'alta'" decoration-danger="state == 'baja'"/>
                <field name="location_id"/>
            </list>
        </field>
    </record>
    <record id="view_localiza_puesto_form" model="ir.ui.view">
        <field name="name">localiza.puesto.form</field>
        <field name="model">localiza.puesto</field>
        <field name="arch" type="xml">
            <form string="Puesto">
                <header>
                    <button name="action_alta" type="object" string="Dar alta" class="btn-primary" invisible="state == 'alta'"/>
                    <button name="action_baja" type="object" string="Dar baja" invisible="state == 'baja'"/>
                    <field name="state" widget="statusbar" statusbar_visible="alta,baja"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_entregas" type="object" class="oe_stat_button" icon="fa-truck">
                            <field name="entrega_count" widget="statinfo" string="Entregas"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del puesto"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="tipo"/>
                            <field name="partner_id"/>
                            <field name="supervisor_id"/>
                            <field name="agentes"/>
                        </group>
                        <group>
                            <field name="fecha_inicio"/>
                            <field name="fecha_baja" invisible="state == 'alta'"/>
                            <field name="location_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="address"/>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_localiza_puesto" model="ir.actions.act_window">
        <field name="name">Puestos</field>
        <field name="res_model">localiza.puesto</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
