<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_gt_form" model="ir.ui.view">
        <field name="name">hr.employee.form.gt.profile</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Ficha Guatemala" name="gt_profile_page">
                    <group string="Datos Personales">
                        <group string="Información Laboral Base">
                            <field name="department_id" string="Departamento de Trabajo"/>
                            <field name="job_id" string="Puesto de Trabajo"/>
                            <field name="gt_service_position_name"/>
                            <field name="parent_id" string="Responsable de RRHH"/>
                            <field name="name" string="Nombre del Trabajador"/>
                        </group>
                        <group string="Identificación y Contacto">
                            <field name="phone" string="Teléfono Celular"/>
                            <field name="gt_home_phone"/>
                            <field name="gt_age" readonly="1"/>
                            <field name="gt_dpi"/>
                            <field name="gt_dpi_extended_place"/>
                            <field name="gt_nit"/>
                            <field name="gt_igss_number"/>
                        </group>
                        <group string="Nacimiento y Estado Civil">
                            <field name="birthday" string="Fecha de Nacimiento"/>
                            <field name="marital" string="Estado Civil"/>
                            <field name="place_of_birth" string="Lugar de Nacimiento"/>
                            <field name="country_of_birth" string="País de Nacimiento"/>
                        </group>
                        <group string="Residencia">
                            <field name="gt_full_address"/>
                            <field name="gt_housing_type"/>
                            <field name="gt_residence_time"/>
                            <field name="gt_residence_municipality"/>
                            <field name="gt_residence_department"/>
                            <field name="emergency_contact" string="Contacto de Emergencia"/>
                            <field name="emergency_phone" string="Teléfono de Emergencia"/>
                        </group>
                        <group string="Datos Económicos" colspan="2">
                            <group>
                                <field name="gt_has_other_income"/>
                                <field name="gt_other_income_notes" invisible="not gt_has_other_income"/>
                                <field name="gt_has_vehicle"/>
                                <field name="gt_vehicle_type" invisible="not gt_has_vehicle"/>
                                <field name="gt_vehicle_brand" invisible="not gt_has_vehicle"/>
                            </group>
                            <group>
                                <field name="gt_has_debts"/>
                                <field name="gt_debt_amount" invisible="not gt_has_debts"/>
                            </group>
                            <field name="gt_address_notes" colspan="2" placeholder="Direcciones, referencias de ubicación u observaciones"/>
                        </group>
                    </group>
                </page>

                <page string="Datos Familiares" name="gt_family_page">
                    <group>
                        <group string="Padres">
                            <field name="gt_father_name"/>
                            <field name="gt_father_phone"/>
                            <field name="gt_mother_name"/>
                            <field name="gt_mother_phone"/>
                        </group>
                        <group string="Cónyuge e Hijos">
                            <field name="spouse_complete_name" string="Nombre del Cónyuge"/>
                            <field name="gt_spouse_phone"/>
                            <field name="gt_spouse_address"/>
                            <field name="children" string="Número de Hijos"/>
                            <field name="gt_siblings_count"/>
                        </group>
                    </group>
                </page>

                <page string="Salud" name="gt_health_page">
                    <group>
                        <group string="Hábitos y Medidas">
                            <field name="gt_smokes"/>
                            <field name="gt_drinks"/>
                            <field name="gt_sports"/>
                            <field name="gt_weight"/>
                            <field name="gt_height"/>
                            <field name="gt_blood_type"/>
                        </group>
                        <group string="Condiciones Médicas">
                            <field name="gt_disabilities"/>
                            <field name="gt_disease"/>
                            <field name="gt_medication"/>
                        </group>
                    </group>
                </page>

                <page string="Experiencia Laboral" name="gt_experience_page">
                    <field name="gt_experience_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="company_name"/>
                            <field name="position"/>
                            <field name="time_worked"/>
                            <field name="salary"/>
                            <field name="leaving_reason"/>
                            <field name="immediate_boss"/>
                            <field name="company_phone"/>
                            <field name="can_request_reference"/>
                        </list>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="company_name"/>
                                        <field name="position"/>
                                        <field name="time_worked"/>
                                        <field name="salary"/>
                                    </group>
                                    <group>
                                        <field name="leaving_reason"/>
                                        <field name="immediate_boss"/>
                                        <field name="company_phone"/>
                                        <field name="can_request_reference"/>
                                    </group>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>

                <page string="Referencias Personales" name="gt_references_page">
                    <field name="gt_reference_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="relationship"/>
                        </list>
                    </field>
                </page>

                <page string="Estudios" name="gt_education_page">
                    <group string="Estudios">
                        <field name="gt_education_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="degree"/>
                                <field name="year"/>
                                <field name="institution"/>
                                <field name="currently_studying"/>
                                <field name="schedule"/>
                            </list>
                        </field>
                    </group>
                    <group string="Otros / Estudios Técnicos">
                        <field name="gt_technical_study_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="technical_study"/>
                                <field name="degree"/>
                                <field name="year"/>
                                <field name="institution"/>
                            </list>
                        </field>
                    </group>
                </page>

                <page string="Trabajo" name="gt_work_page">
                    <group>
                        <group string="Asignación">
                            <field name="gt_service_position_name"/>
                            <field name="gt_entry_date"/>
                            <field name="gt_reentry_date"/>
                            <field name="gt_service_address"/>
                            <field name="coach_id" string="Jefe Inmediato"/>
                            <field name="gt_assigned_department"/>
                        </group>
                        <group string="Condiciones">
                            <field name="gt_position_change_date"/>
                            <field name="gt_new_position_name"/>
                            <field name="gt_current_salary"/>
                            <field name="gt_contract_condition"/>
                            <field name="gt_benefits"/>
                        </group>
                    </group>
                </page>

                <page string="Documentos Guatemala" name="gt_documents_page">
                    <field name="gt_document_ids" nolabel="1">
                        <list editable="bottom" decoration-danger="expiration_state == 'expired'" decoration-warning="expiration_state == 'warning'">
                            <field name="document_type"/>
                            <field name="name"/>
                            <field name="issue_date"/>
                            <field name="expiration_date"/>
                            <field name="days_to_expire" readonly="1"/>
                            <field name="expiration_state" readonly="1"/>
                            <field name="attachment" filename="attachment_filename"/>
                            <field name="attachment_filename" column_invisible="1"/>
                        </list>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="document_type"/>
                                        <field name="name"/>
                                        <field name="issue_date"/>
                                        <field name="expiration_date"/>
                                        <field name="expiration_state" readonly="1"/>
                                        <field name="days_to_expire" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="attachment_filename" invisible="1"/>
                                        <field name="attachment" filename="attachment_filename"/>
                                        <field name="notes"/>
                                    </group>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_hr_employee_gt_document_list" model="ir.ui.view">
        <field name="name">hr.employee.gt.document.list</field>
        <field name="model">hr.employee.gt.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="expiration_state == 'expired'" decoration-warning="expiration_state == 'warning'">
                <field name="employee_id"/>
                <field name="document_type"/>
                <field name="name"/>
                <field name="issue_date"/>
                <field name="expiration_date"/>
                <field name="days_to_expire"/>
                <field name="expiration_state"/>
            </list>
        </field>
    </record>

    <record id="action_hr_employee_gt_documents" model="ir.actions.act_window">
        <field name="name">Documentos Guatemala</field>
        <field name="res_model">hr.employee.gt.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hr_employee_gt_documents"
              name="Documentos Guatemala"
              parent="hr.menu_hr_root"
              action="action_hr_employee_gt_documents"
              sequence="95"/>
</odoo>
